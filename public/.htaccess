<IfModule mod_authz_core.c>
    Require all granted
</IfModule>

# Security: do not list directories
Options -Indexes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Optional: canonical www (matches app.url). Uncomment if you use www.webspace.ng
    # RewriteCond %{HTTP_HOST} ^webspace\.ng$ [NC]
    # RewriteRule ^ https://www.webspace.ng%{REQUEST_URI} [L,R=301]

    # MUST match the URL path to this folder (no trailing slash). Examples:
    #   Site is https://example.com/billo/  →  RewriteBase /billo
    #   Site is https://example.com/       →  RewriteBase /
    # If you get host 404s, try commenting RewriteBase entirely (some hosts set it automatically).
    RewriteBase /billo

    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    RewriteRule ^ index.php [L]
</IfModule>
