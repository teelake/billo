<IfModule mod_authz_core.c>
    Require all granted
</IfModule>
<IfModule !mod_authz_core.c>
    Order allow,deny
    Allow from all
</IfModule>

# Stops /login being treated as "login.something" (MultiViews) and 404ing before rewrite.
# +FollowSymLinks: required for mod_rewrite on many hosts (Hostinger / LiteSpeed).
Options -Indexes +FollowSymLinks -MultiViews
DirectoryIndex index.php

# If mod_rewrite is flaky, this still sends unknown URLs to index.php (Apache 2.4+ / LiteSpeed).
<IfModule mod_dir.c>
    FallbackResource index.php
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # This file sits next to index.php when ONLY /public was copied into public_html/billo/.
    # Must match URL segment to that folder and config app.base_path (case-sensitive on Linux).
    # For install at domain root (DocumentRoot = this folder), use: RewriteBase /
    RewriteBase /billo/

    # Optional: apex → www (edit domain if needed)
    # RewriteCond %{HTTP_HOST} ^webspace\.ng$ [NC]
    # RewriteRule ^ https://www.webspace.ng%{REQUEST_URI} [L,R=301]

    RewriteRule ^index\.php$ - [L]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule .* index.php [QSA,L]
</IfModule>
